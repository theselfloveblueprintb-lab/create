# ============================================================
# REQUIRED — the app will not generate any AI content without this.
# Server-side only. Read in app/api/plan, app/api/workout/generate
# (via generateWorkoutCore.ts), and app/api/planner/generate (via
# planningSequence.ts). NEVER exposed to the browser bundle.
# ============================================================
ANTHROPIC_API_KEY=

# Configurable daily request ceiling per client (see lib/api/rateLimiter.ts).
# Optional — defaults to 150 if unset. This is an in-memory, per-server-
# instance limit, not a distributed one; see MIGRATION_PLAN.md.
DAILY_AI_REQUEST_LIMIT=150

# ============================================================
# OPTIONAL — Supabase (PRD-005). Not required for Local Private Test
# Mode, which is the default and only mode that's genuinely live today.
# See MIGRATION_PLAN.md before setting these up: no live Supabase
# project exists yet, no auth system exists yet, and connecting these
# does NOT automatically migrate existing localStorage data.
# ============================================================

# Public — safe to expose to the browser (used by Supabase's client SDK
# once real auth is built). Get this from your Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=

# Public anon/publishable key — also safe for the browser. This is NOT
# the same as the service role key below; Supabase issues both
# separately from the same project settings page.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SERVER-ONLY. Full database access, bypasses Row Level Security.
# Used exclusively in lib/db/supabaseClient.ts. Must NEVER be prefixed
# with NEXT_PUBLIC_, must NEVER be referenced from any Client Component,
# and must NEVER appear in git history or a screenshot.
SUPABASE_SERVICE_ROLE_KEY=
